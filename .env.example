# ACOLHE Foz · API — variáveis de ambiente (RNF-052)
NODE_ENV=development
PORT=3000

# Banco de dados (PostgreSQL 16 + PostGIS)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/acolhefoz

# JWT (chaves DIFERENTES entre si, >= 32 chars) — RNF-012
JWT_SECRET=troque-esta-chave-de-acesso-com-no-minimo-32-chars
JWT_REFRESH_SECRET=troque-esta-chave-de-refresh-diferente-32-chars
JWT_EXPIRATION=15m
REFRESH_EXPIRATION=7d

# CORS — origens do dashboard e do app (lista branca) — RNF-014
CORS_ORIGIN=http://localhost:5173,http://localhost:19006,http://localhost:8081

# Rate limit (RNF-013)
THROTTLE_TTL=60
THROTTLE_LIMIT=100
